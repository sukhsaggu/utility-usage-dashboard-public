# Copy to prod.tfvars (gitignored) and edit for your cluster.
#   cp prod.tfvars.example prod.tfvars

environment         = "prod"
kube_context        = "your-kubectl-context-prod"
gateway_host        = "10.0.0.2"
ingress_path_prefix = "gas-dashboard"
namespace           = "utility"
app_name            = "utility-usage-dashboard"
image               = "YOUR_REGISTRY/utility-usage-dashboard:1.0.0"
image_pull_policy   = "Always"
dashboard_username  = "admin"
dashboard_password  = "change-me-strong-unique-password"
